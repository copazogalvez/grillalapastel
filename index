const SEMANAS = [
  { label:"Semana 1", sub:"Semana Santa · compartir sin contexto religioso",
    days:["2026-03-30","2026-03-31","2026-04-01","2026-04-02","2026-04-03","2026-04-04","2026-04-05"] },
  { label:"Semana 2", sub:"Vuelta a la rutina · humor cotidiano + antojo",
    days:["2026-04-06","2026-04-07","2026-04-08","2026-04-09","2026-04-10","2026-04-11","2026-04-12"] },
  { label:"Semana 3", sub:"Día de la Cocina Chilena · identidad y orgullo",
    days:["2026-04-13","2026-04-14","2026-04-15","2026-04-16","2026-04-17","2026-04-18","2026-04-19"] },
  { label:"Semana 4", sub:"Siembra Día de la Madre · emoción sin presión",
    days:["2026-04-20","2026-04-21","2026-04-22","2026-04-23","2026-04-24","2026-04-25","2026-04-26"] },
  { label:"Semana 5", sub:"Cierre de abril · urgencia real + gratitud",
    days:["2026-04-27","2026-04-28","2026-04-29","2026-04-30","2026-05-01","2026-05-02","2026-05-03"] },
];

const DAY_NUMS = {};
["2026-03-30","2026-03-31"].forEach((d,i)=>DAY_NUMS[d]=30+i);
for(let i=1;i<=30;i++) DAY_NUMS[`2026-04-${String(i).padStart(2,'0')}`]=i;
for(let i=1;i<=3;i++) DAY_NUMS[`2026-05-0${i}`]=i;

const isAprilOrMar31 = d => d.startsWith("2026-04") || d==="2026-03-31";
const isGray = d => d.startsWith("2026-03-30") || d.startsWith("2026-05");
const MONTHS = ["ene","feb","mar","abr","may","jun","jul","ago","sep","oct","nov","dic"];
const DNAMES = ["domingo","lunes","martes","miércoles","jueves","viernes","sábado"];
const TYPE = {story:"Historia",post:"Post",reel:"Reel",cumple:"Post 🎂"};
const BADGECLS = {story:"badge-story",post:"badge-post",reel:"badge-reel",cumple:"badge-cumple"};

function buildCal(){
  const cal = document.getElementById("calendar");
  SEMANAS.forEach((sem, si)=>{
    const banner = document.createElement("div");
    banner.className = "semana-banner";
    banner.innerHTML = `<span>${sem.label}</span><em>${sem.sub}</em>`;
    cal.appendChild(banner);

    const row = document.createElement("div");
    row.className = `week-row week-${si}`;

    sem.days.forEach(date=>{
      const cell = document.createElement("div");
      const c = CONTENT[date];
      const num = DAY_NUMS[date];
      const active = isAprilOrMar31(date);
      const gray = isGray(date);

      cell.className = "day-cell" + (c?" has-content":"") + (date==="2026-03-30"?" today":"");
      if(!num){ cell.className="day-cell empty"; row.appendChild(cell); return; }

      const numCls = date==="2026-03-30"?"today-num":gray?"gray-num":"";
      const monthLabel = gray ? `<span style="font-size:9px;opacity:0.5;margin-left:2px">${date.startsWith("2026-03")?"mar":"may"}</span>` : "";

      if(!active){
        cell.innerHTML=`<div class="day-top"><span class="day-number gray-num">${num}${monthLabel}</span></div>`;
      } else if(c){
        const sesionBanner = c.sesionGrabacion ? `
          <div class="sesion-banner">
            <span>📹 SESIÓN DE GRABACIÓN</span>
            <em>Contenido del mes + Día de la Madre</em>
          </div>` : "";
        cell.innerHTML=`
          <div class="day-top">
            <span class="day-number ${numCls}">${num}</span>
            <span class="badge ${BADGECLS[c.type]}">${TYPE[c.type]}</span>
          </div>
          <div class="cell-body">
            ${sesionBanner}
            <div class="cell-title">${c.title}</div>
            <div class="cell-obj">${c.objetivo}</div>
            <div class="cell-copy">${c.copy.split('\n')[0]}</div>
            ${c.produccion?`<div class="prod-tag">📷 antes del ${c.produccion}</div>`:""}
          </div>`;
        cell.onclick = ()=>openModal(date, c);
      } else {
        cell.innerHTML=`<div class="day-top"><span class="day-number">${num}</span></div>`;
      }
      row.appendChild(cell);
    });
    cal.appendChild(row);
  });
}

function openModal(date, c){
  const d = new Date(date+"T12:00:00");
  document.getElementById("mFecha").textContent = `${DNAMES[d.getDay()]}, ${d.getDate()} de ${MONTHS[d.getMonth()]}`;
  document.getElementById("mBadge").innerHTML = `<span class="badge ${BADGECLS[c.type]}" style="font-size:10px">${TYPE[c.type]}</span>`;
  document.getElementById("mTitulo").textContent = c.title;

  let html = "";

  if(c.sesionGrabacion){
    html += `<div class="sesion-modal-box">
      <h4>📹 SESIÓN DE GRABACIÓN — 13 de abril</h4>
      <p>Este día está definido para grabar todo el contenido de la segunda quincena del mes + el contenido del Día de la Madre.</p>
      <ul>
        <li>🍰 <strong>Definir antes de esta fecha:</strong> producto(s) estrella del mes</li>
        <li>🤍 <strong>Definir antes de esta fecha:</strong> producto(s) para Día de la Madre (10 mayo)</li>
        <li>📦 Tener lista la presentación / embalaje de regalo si hay</li>
        <li>🎬 Preparar set de fotos y video: luz, fondo, props</li>
        <li>📋 Revisar grilla completa antes de grabar para no olvidar ninguna pieza</li>
      </ul>
    </div>`;
  }

  html += `<div class="modal-sec"><label>Objetivo</label><p>${c.objetivo}</p></div>`;
  html += `<div class="modal-sec"><label>Concepto</label><p>${c.concepto}</p></div>`;
  html += `<div class="modal-sec"><label>Idea visual</label><p>${c.visual}</p></div>`;

  if(c.hook){
    html += `<div class="modal-sec"><div class="hook-label">🎬 Hook de entrada — primeros 2 segundos</div><div class="hook-box">"${c.hook}"</div></div>`;
  }

  html += `<div class="modal-sec"><label>Copy listo</label><div class="copy-box">${c.copy.replace(/\n/g,'<br>')}</div></div>`;

  if(c.estrategia){
    html += `<div class="modal-sec"><label>Por qué funciona</label><div class="strategy-box">${c.estrategia}</div></div>`;
  }

  if(c.producto){
    html += `<div class="modal-sec"><label>Producto</label><p><span class="prod-badge">${c.producto}</span></p></div>`;
  }

  html += `<div class="modal-sec"><label>Etiquetas</label><div class="tags">${c.tags.map((t,i)=>`<span class="tag${i===0?" hot":""}">${t}</span>`).join("")}</div></div>`;
  html += `<div class="modal-sec"><label>Producción</label><p>📷 Grabar antes del <strong>${c.produccion}</strong></p></div>`;

  document.getElementById("mBody").innerHTML = html;
  document.getElementById("overlay").classList.add("active");
}

function closeModal(){ document.getElementById("overlay").classList.remove("active"); }
function closeMaybe(e){ if(e.target===document.getElementById("overlay")) closeModal(); }
document.addEventListener("keydown", e=>{ if(e.key==="Escape") closeModal(); });

buildCal();
</script>
