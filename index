  .sesion-banner span { font-size: 9px; font-weight: 700; color: #7ADAA0; letter-spacing: 0.5px; line-height: 1.4; display: block; }
  .sesion-banner em { font-size: 8.5px; color: #A0C8A8; font-style: normal; line-height: 1.4; display: block; margin-top: 1px; }
  .sesion-modal-box { background: linear-gradient(135deg, #1A3A2A, #2A5A3A); border-radius: 10px; padding: 14px 16px; margin-bottom: 4px; }
