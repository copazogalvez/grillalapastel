  .sesion-modal-box ul li { font-size: 12.5px; color: #C0E8C8; line-height: 1.8; }

  /* MODAL */
  .modal-overlay {
    position: fixed; inset: 0; background: rgba(40,25,15,0.7);
    backdrop-filter: blur(5px); z-index: 200;
    display: flex; align-items: center; justify-content: center; padding: 20px;
    opacity: 0; pointer-events: none; transition: opacity 0.2s ease;
  }
  .modal-overlay.active { opacity: 1; pointer-events: all; }
  .modal {
    background: var(--warm-white); border-radius: 14px;
    max-width: 580px; width: 100%; max-height: 88vh; overflow-y: auto;
    box-shadow: 0 24px 64px rgba(40,20,10,0.35);
    transform: translateY(10px); transition: transform 0.2s ease;
  }
  .modal-overlay.active .modal { transform: translateY(0); }

  .modal-hdr {
    padding: 22px 26px 14px; border-bottom: 1px solid var(--border);
    display: flex; justify-content: space-between; align-items: flex-start; gap: 12px;
    position: sticky; top: 0; background: var(--warm-white); z-index: 1;
