  .modal-hdr-left { display: flex; flex-direction: column; gap: 6px; }
  .modal-fecha { font-size: 11px; color: var(--brown-mid); letter-spacing: 1px; text-transform: uppercase; }
  .modal-titulo { font-family: 'Playfair Display', serif; font-size: 20px; color: var(--brown-dark); line-height: 1.2; margin-top: 4px; }
  .modal-close { background: none; border: none; font-size: 20px; color: var(--brown-mid); cursor: pointer; flex-shrink: 0; line-height: 1; padding: 2px; transition: color 0.15s; }
  .modal-close:hover { color: var(--brown-dark); }

  .modal-body { padding: 18px 26px 26px; display: flex; flex-direction: column; gap: 16px; }
  .modal-sec label { display: block; font-size: 9px; font-weight: 700; letter-spacing: 1.8px; text-transform: uppercase; color: var(--caramel); margin-bottom: 6px; }
  .modal-sec p { font-size: 13.5px; color: var(--brown-dark); line-height: 1.65; }

