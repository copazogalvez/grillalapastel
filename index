    padding: 32px 48px 24px;
    display: flex; align-items: flex-end; justify-content: space-between; gap: 24px;
  }
  .header h1 { font-family: 'Playfair Display', serif; font-size: 40px; color: var(--cream); line-height: 1; letter-spacing: -1px; }
  .header h1 span { color: var(--caramel-light); font-style: italic; }
  .header p { color: #A09080; font-size: 12px; margin-top: 6px; letter-spacing: 2px; text-transform: uppercase; }
  .legend { display: flex; gap: 18px; align-items: center; flex-wrap: wrap; }
  .legend-item { display: flex; align-items: center; gap: 6px; color: #C0B0A0; font-size: 11px; letter-spacing: 0.5px; font-weight: 500; }
  .legend-dot { width: 9px; height: 9px; border-radius: 50%; }

  .stats-bar { background: #013537; padding: 12px 48px; display: flex; gap: 32px; align-items: center; border-bottom: 3px solid #e09b00; }
  .stat { display: flex; align-items: center; gap: 8px; color: #fff5e0; font-size: 12px; }
  .stat strong { font-size: 20px; font-family: 'Playfair Display', serif; color: #ffc8ad; }

  .alert-bar {
    background: #fff5e0; border-bottom: 1px solid #e09b00;
    padding: 10px 48px; font-size: 12px; color: #013537;
    display: flex; gap: 24px; align-items: center; flex-wrap: wrap;
  }
  .alert-bar strong { color: #013537; }

  .calendar-wrapper { padding: 28px 48px 48px; }

  .week-header { display: grid; grid-template-columns: repeat(7, 1fr); gap: 4px; margin-bottom: 4px; }
  .day-name { text-align: center; font-size: 10px; font-weight: 600; letter-spacing: 1.5px; text-transform: uppercase; color: var(--brown-mid); padding: 6px 0; }

  .semana-banner {
    background: linear-gradient(135deg, #013537, #2a6b5e);
    color: var(--cream); padding: 9px 16px;
    font-size: 10px; letter-spacing: 2px; text-transform: uppercase; font-weight: 600;
    display: flex; justify-content: space-between; align-items: center;
    border-radius: 6px 6px 0 0; margin-top: 6px;
  }
  .semana-banner em { color: #ffc8ad; font-style: italic; font-family: 'Playfair Display', serif; font-size: 12px; letter-spacing: 0; text-transform: none; font-weight: 400; }

  .week-row { display: grid; grid-template-columns: repeat(7, 1fr); gap: 4px; margin-bottom: 2px; }

  .day-cell {
    background: var(--warm-white); border: 1px solid var(--border);
    border-radius: 6px; min-height: 148px; overflow: hidden;
    transition: transform 0.15s ease, box-shadow 0.15s ease;
    position: relative;
  }
  .day-cell.empty { background: transparent; border-color: transparent; }
  .day-cell.has-content { cursor: pointer; }
  .day-cell.has-content:hover { transform: translateY(-2px); box-shadow: 0 6px 20px rgba(1,53,55,0.13); z-index: 10; }
  .day-cell.today { border-color: var(--caramel); border-width: 2px; }
  /* Week tint colors using brand palette */
  .week-0 .day-cell { background: #fffdf5; }
  .week-1 .day-cell { background: #fff9f5; }
  .week-2 .day-cell { background: #f5fbf4; }
  .week-3 .day-cell { background: #f5f9fd; }
  .week-4 .day-cell { background: #fff8f5; }

  .day-top { padding: 7px 8px 4px; display: flex; justify-content: space-between; align-items: center; }
  .day-number { font-size: 12px; font-weight: 600; color: var(--brown-mid); }
  .day-number.today-num { color: var(--caramel); }
  .day-number.gray-num { color: #CCC; font-weight: 400; }

  .badge { font-size: 9px; font-weight: 700; letter-spacing: 0.8px; text-transform: uppercase; padding: 2px 6px; border-radius: 20px; color: white; }
  .badge-story { background: var(--story-color); }
  .badge-post { background: var(--post-color); }
  .badge-reel { background: var(--reel-color); }
  .badge-cumple { background: var(--cumple-color); }

  .cell-body { padding: 2px 8px 8px; }
  .cell-title { font-family: 'Playfair Display', serif; font-size: 11.5px; font-weight: 700; color: var(--brown-dark); line-height: 1.3; margin-bottom: 4px; }
  .cell-obj { font-size: 9px; color: var(--caramel); font-weight: 600; letter-spacing: 0.8px; text-transform: uppercase; margin-bottom: 5px; }
  .cell-copy { font-size: 10.5px; color: #6A5548; line-height: 1.5; font-style: italic; border-left: 2px solid var(--border); padding-left: 6px; }

